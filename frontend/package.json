{
  "name": "nexus-terminal-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "generate:seo": "node scripts/generate-seo.mjs",
    "predev": "npm run generate:seo",
    "dev": "vite",
    "prebuild": "npm run generate:seo",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "verify:foundation": "node scripts/verify-foundation.mjs",
    "verify:realtime": "node scripts/verify-realtime-client.mjs",
    "verify:scanner-realtime": "node scripts/verify-scanner-realtime.mjs",
    "verify:watchlist-realtime": "node scripts/verify-watchlist-realtime.mjs",
    "verify:market-realtime": "node scripts/verify-market-realtime.mjs",
    "test:realtime": "tsc -p tsconfig.realtime-test.json && node --test test/realtime-client.test.mjs test/scanner-realtime.test.mjs test/watchlist-realtime.test.mjs test/market-realtime.test.mjs test/alerts-realtime.test.mjs test/workspace-realtime.test.mjs",
    "check": "npm run verify:foundation && npm run verify:realtime && npm run verify:scanner-realtime && npm run verify:watchlist-realtime && npm run verify:market-realtime && npm run verify:alerts-realtime && npm run verify:workspace-realtime && npm run typecheck && npm run test:realtime",
    "verify:alerts-realtime": "node scripts/verify-alerts-realtime.mjs",
    "verify:workspace-realtime": "node scripts/verify-workspace-realtime.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  }
}
