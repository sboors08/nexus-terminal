NODE_ENV=development
HOST=0.0.0.0
PORT=4100
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

BINANCE_BASE_URL=https://data-api.binance.vision
BINANCE_REQUEST_TIMEOUT_MS=5000
BINANCE_SYMBOLS_LIMIT=100
BINANCE_CACHE_TTL_MS=15000

BINANCE_WS_ENABLED=true
BINANCE_WS_BASE_URL=wss://data-stream.binance.vision
BINANCE_WS_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
BINANCE_WS_RECONNECT_BASE_DELAY_MS=1000
BINANCE_WS_RECONNECT_MAX_DELAY_MS=30000
BINANCE_WS_TRADES_BUFFER_SIZE=100
