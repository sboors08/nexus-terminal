{
  "name": "nexus-terminal-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.22.0",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test test/health.test.ts test/api-contract.test.ts",
    "verify:foundation": "node scripts/verify-foundation.mjs",
    "check": "npm run verify:foundation && npm run typecheck && npm test"
  },
  "dependencies": {
    "@fastify/cors": "11.3.0",
    "fastify": "5.10.0"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
